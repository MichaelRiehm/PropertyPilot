# Used when the frontend is built from its own directory as the Docker
# context. The default compose build uses the repo root and the root
# .dockerignore; these rules mirror it for a package-scoped build.

node_modules
dist
coverage
*.tsbuildinfo

# Local env files.
.env
.env.local
.env.*.local
!.env.example

# Dev / IDE noise.
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
*.log

# Frontend tests aren't shipped in the image.
src/**/*.test.ts
src/**/*.test.tsx
