# Copy this file to .env and fill in real values. Do not commit .env.

# PostgreSQL connection string used by Prisma. Matches docker-compose.yml defaults.
DATABASE_URL="postgresql://propertypilot:propertypilot@localhost:5432/propertypilot?schema=public"

# Secret used to sign JWTs. Generate a long random string for any non-local environment.
JWT_SECRET="change-me-to-a-long-random-string"

# Port the backend Express server listens on.
PORT=4000

# Origin allowed by the backend CORS middleware (the frontend dev server URL).
FRONTEND_URL="http://localhost:5173"

# Cloudflare R2 (or any S3-compatible object storage) for lease document uploads.
# Leave these blank to run without the upload feature — the routes will 404 and
# the frontend Upload PDF button will surface the error to the user.
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
